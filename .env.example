# ─────────────────────────────────────────────────────────────────────────────
# Restaurant Intelligence Platform — Environment Variables
# Copy this file to `.env` and fill in the values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (Supabase) ───────────────────────────────────────────────────────
# Go to: Supabase Dashboard → Project Settings → Database → Connection string → URI
# Use the "Session pooler" string (port 5432) — recommended for FastAPI/SQLAlchemy
#
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
#
DATABASE_URL=postgresql://postgres.[project-ref]:[db-password]@aws-0-[region].pooler.supabase.com:5432/postgres

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=Restaurant Intelligence Platform
SECRET_KEY=change-me-to-a-random-string-of-at-least-32-characters
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── OpenAI (optional — enables LLM correlations and insights) ─────────────────
OPENAI_API_KEY=

# ── Stripe (optional — enables billing) ──────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_STARTER=
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_PREMIUM=

# ── Email / SMTP (optional — enables daily briefing emails) ───────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
